{
  "name": "pointing-poker-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client",
    "deploy": "npm run deploy:server && npm run deploy:client",
    "deploy:server": "npm run deploy -w server",
    "deploy:client": "npm run build -w client",
    "preview": "npm run preview -w client",
    "clean": "rm -rf node_modules client/node_modules server/node_modules client/dist"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
